class Solution {
public:
    int earliestFinishTime(vector<int>& landStartTime, vector<int>& landDuration, vector<int>& waterStartTime, vector<int>& waterDuration) {
         int ans = INT_MAX;
        for (int i = 0; i < landStartTime.size(); i++) {
            for (int j = 0; j < waterStartTime.size(); j++) {
                // Plan A: water -> land
                int waterFinish = waterStartTime[j] + waterDuration[j];
                int landFinish = max(landStartTime[i], waterFinish) + landDuration[i];
                ans = min(ans, landFinish);

                // Plan B: land -> water
                int landFinish2 = landStartTime[i] + landDuration[i];
                int waterFinish2 = max(waterStartTime[j], landFinish2) + waterDuration[j];
                ans = min(ans, waterFinish2);
            }
        }
        return ans;
    }
};
