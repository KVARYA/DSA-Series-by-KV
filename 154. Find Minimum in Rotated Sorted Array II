class Solution {
public:
    int findMin(vector<int>& nums) {
        if(nums.size() == 0) return 0;

        sort(nums.begin(), nums.end());
        int result = nums[0];

        return result;
    }
};

//Alternative Approach
class Solution {
public:
    int findMin(vector<int>& nums) {
        int s = 0;
        int e = nums.size() - 1;

        while (s < e) {
            int mid = s + (e - s) / 2;

            if (nums[mid] > nums[e]) {
                s = mid + 1;
            }
            else if (nums[mid] < nums[e]) {
                e = mid;
            }
            else {
                e--;
            }
        }

        return nums[s];
    }
};
