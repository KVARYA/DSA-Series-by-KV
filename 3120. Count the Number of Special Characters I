class Solution {
public:
    int numberOfSpecialChars(string word) {
        // Use a set for quick membership checks
        unordered_set<char> s(word.begin(), word.end());
        
        int result = 0;
        for (char c = 'a'; c <= 'z'; ++c) {
            if (s.count(c) && s.count(toupper(c))) {
                result++;
            }
        }
        return result;
    }
};

