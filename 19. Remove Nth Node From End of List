class Solution {
public:
     int travel_front(ListNode* head) {
        int length = 0;
        while(head) {
            length++;
            head= head->next;
        }
        return length;
    }
    ListNode* removeNthFromEnd(ListNode* head, int n) {
        int L = travel_front(head);
        if(n==L) {
            ListNode* temp = head->next;
            delete(head);
            return temp;
        }

        int travel_front = L-n;
        ListNode* temp = head;
        ListNode* prev = NULL;

        while(travel_front--) {
            prev= temp;
            temp = temp->next;
        }
        prev->next = temp->next;
        delete (temp);

        return head;
       
    }
};
