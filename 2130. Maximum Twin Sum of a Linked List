class Solution {
public:
    int pairSum(ListNode* head) {
        vector<int> nums;
        ListNode* curr = head;

        while(curr != NULL) {
            nums.push_back(curr->val);
            curr = curr->next;
        }

        int result = 0;
        int i =0; 
        int j = nums.size()- 1;

        while (i<j) {
            result = max(result, nums[i]+nums[j]);
            i++;
            j--;
        }
        return result;
    }
};
