class Solution {
public:
    int minimumCost(vector<int>& cost) {
        sort(cost.begin(), cost.end());

        int ans = 0;

        for(int i=cost.size()-1; i>=0; i=i-3){
            if(i-1>=0) ans += cost[i] + cost[i-1];
            else ans += cost[i];
        }

        return ans;
    }
};



///////////////////////////////////////////////////////////////////

class Solution {
public:
    int minimumCost(vector<int>& a) {
        // total sum
        int total = accumulate(a.begin(), a.end(), 0);

        // sort array
        sort(a.begin(), a.end());

        // sum of every 3rd element from the end
        int discount = 0;
        for (int i = a.size() - 3; i >= 0; i -= 3) {
            discount += a[i];
        }

        return total - discount;
    }
};
